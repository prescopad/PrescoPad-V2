{
  "expo": {
    "name": "PrescoPad",
    "slug": "PrescoPad",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f5f4f0"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.prescopad.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "PrescoPad needs microphone access to record consultations for transcription.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#f5f4f0"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.prescopad.app",
      "permissions": [
        "RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-sqlite",
      "expo-secure-store",
      "expo-font",
      "expo-updates"
    ],
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "eas": {
        "projectId": "b76d8fe5-004b-4d26-8aa1-cff898a9abb1"
      }
    }
  }
}
